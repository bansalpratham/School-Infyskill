# Shared env file for running backend services manually

# Mongo
MONGODB_URI=mongodb://127.0.0.1:27017/school_hub

# JWT
JWT_SECRET=change_me_super_secret
AUTH_DISABLED=false

# CORS
CORS_ORIGIN=http://localhost:5173

# API Gateway targets (optional overrides; defaults already exist in gateway)
AUTH_SERVICE_URL=http://localhost:5000
STUDENT_SERVICE_URL=http://localhost:4002
TEACHER_SERVICE_URL=http://localhost:4003
FEES_SERVICE_URL=http://localhost:4004
PAYMENTS_SERVICE_URL=http://localhost:4005
EXAM_SERVICE_URL=http://localhost:4006
ANNOUNCEMENTS_SERVICE_URL=http://localhost:4007
REQUESTS_SERVICE_URL=http://localhost:4008
IMPORT_EXPORT_SERVICE_URL=http://localhost:4009
DASHBOARD_SERVICE_URL=http://localhost:4010
SETTINGS_SERVICE_URL=http://localhost:4014
TEACHER_PROFILE_SERVICE_URL=http://localhost:4011
TEACHER_TIMETABLE_SERVICE_URL=http://localhost:4012
TEACHER_ATTENDANCE_SERVICE_URL=http://localhost:4013
TEACHER_DIARY_SERVICE_URL=http://localhost:4015
