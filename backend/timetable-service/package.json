{
  "name": "timetable-service",
  "private": true,
  "version": "1.0.0",
  "description": "Timetable Service microservice (Node.js, Express, TypeScript, MongoDB) - REST API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@school-hub/shared-middleware": "workspace:*",
    "@school-hub/shared-utils": "workspace:*",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.0.1",
    "helmet": "^7.1.0",
    "mongoose": "^8.7.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "typescript": "^5.8.3",
    "ts-node-dev": "^2.0.0"
  }
}
